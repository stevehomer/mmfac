{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
          "builder": "NIXPACKS",
          "nixpacksPlan": {
                  "phases": {
                            "setup": {
                                        "nixPkgs": ["php82", "php82Extensions.pdo_mysql", "php82Extensions.mbstring", "php82Extensions.xml", "php82Extensions.curl", "php82Extensions.zip", "composer"]
                            },
                            "install": {
                                        "cmds": ["composer install --no-dev --optimize-autoloader"]
                            },
                            "build": {
                                        "cmds": ["php artisan key:generate --force", "php artisan config:cache", "php artisan route:cache"]
                            }
                  }
          }
    },
    "deploy": {
          "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT",
          "healthcheckPath": "/"
    }
}
